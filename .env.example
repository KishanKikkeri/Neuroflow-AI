# .env.example
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# For local dev without a service account file, run:
#   gcloud auth application-default login
# On Cloud Run, ADC picks up the attached service account automatically.
GOOGLE_API_KEY=your-gemini-api-key-for-local-dev

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# ── AlloyDB ───────────────────────────────────────────────────────────────────
# Use Cloud SQL Auth Proxy locally:
#   cloud-sql-proxy <PROJECT>:<REGION>:<INSTANCE> --port 5432
ALLOYDB_HOST=127.0.0.1
ALLOYDB_PORT=5432
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=your-alloydb-password
ALLOYDB_DATABASE=neuroflow

# ── Google Calendar MCP Server ────────────────────────────────────────────────
# Deploy the Calendar MCP server to Cloud Run first, then paste its URL here.
# See: https://github.com/google/model-context-protocol-servers/tree/main/servers/google-calendar
CALENDAR_MCP_URL=https://calendar-mcp-server-<your-hash>-uc.a.run.app/mcp

# ── Optional: Weather ─────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweather-api-key
WEATHER_CITY=San Francisco

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
RELOAD=false
